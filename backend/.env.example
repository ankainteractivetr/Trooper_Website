# ─── Server ───────────────────────────────────────────────
PORT=4000
NODE_ENV=development

# Where the React frontend runs (for CORS). Vite default = 5173
CORS_ORIGIN=http://localhost:5173

# Public base URL of THIS backend (used to build absolute image URLs)
PUBLIC_URL=http://localhost:4000

# ─── MySQL ────────────────────────────────────────────────
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=root
DB_PASSWORD=change_this_mysql_password
DB_NAME=trooper_site

# ─── Auth ─────────────────────────────────────────────────
# CMS admin login password. CHANGE THIS before going live.
ADMIN_USERNAME=trooper
ADMIN_PASSWORD=Trooper387!Vulkan

# Secret used to sign JWT session tokens. CHANGE THIS to a long random string.
JWT_SECRET=replace_me_with_a_long_random_secret_string_0xDEADBEEF
JWT_EXPIRES_IN=7d

# ─── Uploads ──────────────────────────────────────────────
UPLOAD_DIR=uploads
MAX_UPLOAD_MB=12
